---
// V4.6.2 PromoBar (Deo 2026-05-20)
// Renders a single thin promotional bar at the very top of every page,
// ABOVE the sticky header — but only when site.promo.active is true.
// Toggle via src/lib/site.ts -> promo.active.
//
// Sample uses:
//   - Special rates for a corridor (DRC, GCC, China)
//   - Limited-time service launch (e.g. new cold-chain Beira service)
//   - Holiday cutoff dates (last sailings before Christmas)
//
// Dismissable per-session via sessionStorage so a returning visitor
// doesn't see the same banner ten times in one browse.

import { site } from '@/lib/site';

const promo = (site as any).promo;
const isActive = !!(promo && promo.active);
---

{isActive && (
  <div class="promo-bar" data-promo-bar role="region" aria-label="Special offer">
    <div class="promo-bar-inner">
      <span class="promo-bar-label">{promo.label}</span>
      <p class="promo-bar-text">{promo.text}</p>
      {promo.ctaHref && (
        <a href={promo.ctaHref} class="promo-bar-cta">
          {promo.ctaText || 'Learn more'}
          <span aria-hidden="true">&rarr;</span>
        </a>
      )}
      <button type="button" class="promo-bar-close" aria-label="Dismiss this promotion" data-promo-close>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
)}

<style>
  .promo-bar {
    background: linear-gradient(90deg, var(--c-bordeaux) 0%, var(--c-bordeaux-deep) 100%);
    color: var(--c-cream);
    position: relative;
    z-index: 41;
  }
  .promo-bar-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 9px 56px 9px 20px;
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--f-sans);
    font-size: 13.5px;
    line-height: 1.3;
  }
  .promo-bar-label {
    font-family: var(--f-mono);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 4px 8px;
    background: rgba(255, 255, 255, 0.18);
    border-radius: 2px;
    flex-shrink: 0;
  }
  .promo-bar-text {
    margin: 0;
    flex: 1;
    color: var(--c-cream);
    font-weight: 500;
  }
  .promo-bar-cta {
    font-family: var(--f-sans);
    font-size: 13px;
    font-weight: 700;
    color: var(--c-cream);
    text-decoration: none;
    border-bottom: 1px solid rgba(247, 242, 232, 0.5);
    transition: border-color 0.2s ease;
    flex-shrink: 0;
  }
  .promo-bar-cta:hover {
    border-bottom-color: var(--c-cream);
  }
  .promo-bar-cta span {
    margin-left: 6px;
    display: inline-block;
    transition: transform 0.2s ease;
  }
  .promo-bar-cta:hover span {
    transform: translateX(3px);
  }
  .promo-bar-close {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    width: 28px;
    height: 28px;
    border-radius: 9999px;
    background: transparent;
    border: none;
    color: var(--c-cream);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
    opacity: 0.7;
  }
  .promo-bar-close:hover {
    background: rgba(255, 255, 255, 0.15);
    opacity: 1;
  }
  @media (max-width: 720px) {
    .promo-bar-inner {
      padding: 8px 48px 8px 14px;
      gap: 10px;
      flex-wrap: wrap;
    }
    .promo-bar-text {
      flex: 1 1 100%;
      order: 2;
      font-size: 13px;
    }
    .promo-bar-label { order: 1; }
    .promo-bar-cta {
      order: 3;
      font-size: 12.5px;
    }
  }
</style>

<script>
  /* Hide the bar if the visitor already dismissed it this session */
  document.addEventListener('DOMContentLoaded', () => {
    const bar = document.querySelector<HTMLElement>('[data-promo-bar]');
    if (!bar) return;
    if (sessionStorage.getItem('mekluc_promo_bar_dismissed') === '1') {
      bar.style.display = 'none';
      return;
    }
    const close = bar.querySelector('[data-promo-close]');
    close?.addEventListener('click', () => {
      sessionStorage.setItem('mekluc_promo_bar_dismissed', '1');
      bar.style.display = 'none';
    });
  });
</script>
