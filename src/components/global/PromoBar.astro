---
// V4.6.5 PromoBar (Deo 2026-05-20)
// Renders a single thin bar at the very top of every page, ABOVE the sticky
// header, only when site.promo.active is true. Toggle via src/lib/site.ts.
//
// Visual identity (Deo: "toujour utilser les couleur de AEO qui est le bleu,
// noire, sa doit etre identifie par ces couleur"):
//   - Background: deep AEO navy + black gradient stripe
//   - Text: white
//   - Chip: white on black
//   - Marquee animation on the message ("fait defile la bande pour que ca
//     attir l'attention") — text scrolls right -> left, pauses on hover
//
// Sample uses:
//   - AEO trust message (default)
//   - Special rates for a corridor (DRC, GCC, China)
//   - Limited-time service launch (Pharma cold-chain etc.)
//
// Dismissable per-session via sessionStorage.

import { site } from '@/lib/site';

const promo = (site as any).promo;
const isActive = !!(promo && promo.active);
---

{isActive && (
  <div class="promo-bar" data-promo-bar role="region" aria-label="Special offer">
    <div class="promo-bar-inner">
      <span class="promo-bar-label">{promo.label}</span>

      <!-- Marquee viewport -->
      <div class="promo-bar-marquee" aria-live="polite">
        <div class="promo-bar-marquee-track">
          {[...Array(2)].map(() => (
            <span class="promo-bar-marquee-item">
              {promo.text}
              <span class="promo-bar-marquee-sep" aria-hidden="true">&nbsp;&nbsp;◆&nbsp;&nbsp;</span>
            </span>
          ))}
        </div>
      </div>

      {promo.ctaHref && (
        <a href={promo.ctaHref} class="promo-bar-cta">
          {promo.ctaText || 'Learn more'}
          <span aria-hidden="true">&rarr;</span>
        </a>
      )}
      <button type="button" class="promo-bar-close" aria-label="Dismiss this promotion" data-promo-close>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
)}

<style>
  /* V4.7 HOTFIX — Solid AEO blue + black gradient (no shimmer animation, was CPU-heavy on mobile) */
  .promo-bar {
    background: linear-gradient(90deg, #0d1b3d 0%, #1f4e8b 50%, #0d1b3d 100%);
    color: #ffffff;
    position: relative;
    z-index: 41;
    border-bottom: 1px solid #000000;
  }

  .promo-bar-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 9px 56px 9px 0;
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--f-sans);
    font-size: 13.5px;
    line-height: 1.3;
  }

  /* AEO-identified chip: black background, white text */
  .promo-bar-label {
    font-family: var(--f-mono);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 5px 11px;
    background: #000000;
    color: #ffffff;
    flex-shrink: 0;
    margin-left: 20px;
    border-radius: 2px;
  }

  /* Marquee viewport */
  .promo-bar-marquee {
    flex: 1;
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(90deg, transparent 0%, #000 8%, #000 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 8%, #000 92%, transparent 100%);
  }
  .promo-bar-marquee-track {
    display: flex;
    white-space: nowrap;
    animation: promoMarquee 26s linear infinite;
    width: max-content;
  }
  .promo-bar-marquee-track:hover {
    animation-play-state: paused;
  }
  .promo-bar-marquee-item {
    color: #ffffff;
    font-weight: 500;
    padding-right: 0;
  }
  .promo-bar-marquee-sep {
    color: #80b7dd;
    font-weight: 700;
    opacity: 0.85;
  }
  @keyframes promoMarquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .promo-bar-marquee-track { animation: none; }
  }

  /* CTA — white outlined for stronger contrast on the blue+black bar */
  .promo-bar-cta {
    font-family: var(--f-sans);
    font-size: 13px;
    font-weight: 700;
    color: #ffffff;
    text-decoration: none;
    padding: 6px 14px;
    border: 1.5px solid #ffffff;
    border-radius: 2px;
    transition: background 0.2s ease, color 0.2s ease;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .promo-bar-cta:hover {
    background: #ffffff;
    color: #0d1b3d;
  }
  .promo-bar-cta span {
    margin-left: 6px;
    display: inline-block;
    transition: transform 0.2s ease;
  }
  .promo-bar-cta:hover span {
    transform: translateX(3px);
  }

  .promo-bar-close {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    width: 28px;
    height: 28px;
    border-radius: 9999px;
    background: transparent;
    border: none;
    color: #ffffff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
    opacity: 0.7;
  }
  .promo-bar-close:hover {
    background: rgba(255, 255, 255, 0.15);
    opacity: 1;
  }

  @media (max-width: 720px) {
    .promo-bar-inner {
      padding: 8px 44px 8px 0;
      gap: 10px;
    }
    .promo-bar-label {
      margin-left: 14px;
      padding: 4px 9px;
      font-size: 10px;
    }
    .promo-bar-marquee {
      font-size: 12.5px;
    }
    .promo-bar-cta {
      font-size: 12px;
      padding: 5px 10px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const bar = document.querySelector<HTMLElement>('[data-promo-bar]');
    if (!bar) return;
    if (sessionStorage.getItem('mekluc_promo_bar_dismissed') === '1') {
      bar.style.display = 'none';
      return;
    }
    const close = bar.querySelector('[data-promo-close]');
    close?.addEventListener('click', () => {
      sessionStorage.setItem('mekluc_promo_bar_dismissed', '1');
      bar.style.display = 'none';
    });
  });
</script>
