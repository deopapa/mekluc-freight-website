---
// V3.4 PATCH AJOUT A — Floating bubbles "Request a Quote" + "WhatsApp"
// Visible on ALL pages. Bordeaux quote bubble (top) + Green WhatsApp (bottom)
// PATCH AJOUT B — WhatsApp Business official number (Cloud API LIVE 28/05/2026, D5)
// Display name "Mekluc Freight" approved by Meta. Decision D3: official WhatsApp channel.
const WHATSAPP_NUMBER = '27638933653'; // wa.me format, no + no spaces
const WHATSAPP_DISPLAY = '+27 63 893 3653'; // for tooltip only — NOT shown in text on site
const QUOTE_URL = '/contact?quote=1';
---

<div class="floating-actions" aria-label="Quick actions">
  <!-- Bubble 1 — Request a Quote (top) -->
  <a
    href={QUOTE_URL}
    class="fab fab-quote"
    aria-label="Request a quote"
    data-tooltip="Request a quote"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 2 11 13" />
      <path d="m22 2-7 20-4-9-9-4 20-7z" />
    </svg>
  </a>

  <!-- Bubble 2 — WhatsApp (bottom) -->
  <a
    href={`https://wa.me/${WHATSAPP_NUMBER}`}
    target="_blank"
    rel="noopener noreferrer"
    class="fab fab-whatsapp"
    aria-label="Chat on WhatsApp"
    data-tooltip="Chat with us on WhatsApp"
  >
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
    </svg>
  </a>
</div>

<style>
  .floating-actions {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 16px;
    /* Safe area for mobile keyboards / notch */
    padding-bottom: env(safe-area-inset-bottom, 0);
  }

  .fab {
    width: 56px;
    height: 56px;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    opacity: 0;
    transform: translateY(16px);
    animation: fabFadeIn 0.4s ease-out 0.8s forwards;
    position: relative;
    cursor: pointer;
  }

  .fab:hover {
    transform: scale(1.08);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.22);
  }

  .fab:focus-visible {
    outline: 3px solid var(--c-copper);
    outline-offset: 3px;
  }

  .fab-quote {
    background: var(--c-bordeaux);
  }

  .fab-whatsapp {
    background: #25D366;
    animation-delay: 0.95s;
  }

  /* Tooltip left side */
  .fab::before {
    content: attr(data-tooltip);
    position: absolute;
    right: calc(100% + 12px);
    top: 50%;
    transform: translateY(-50%);
    background: var(--c-ink);
    color: var(--c-cream);
    font-family: var(--f-sans);
    font-size: 13px;
    font-weight: 500;
    padding: 8px 14px;
    border-radius: 4px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .fab::after {
    content: '';
    position: absolute;
    right: calc(100% + 6px);
    top: 50%;
    transform: translateY(-50%);
    border: 6px solid transparent;
    border-left-color: var(--c-ink);
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  .fab:hover::before,
  .fab:hover::after,
  .fab:focus-visible::before,
  .fab:focus-visible::after {
    opacity: 1;
  }

  @keyframes fabFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Hide tooltip on touch devices (no hover) */
  @media (hover: none) {
    .fab::before,
    .fab::after {
      display: none;
    }
  }
</style>
