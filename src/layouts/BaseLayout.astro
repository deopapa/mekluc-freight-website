    }

    /* V4.1 — Nav link hover with bordeaux underline animation */
    .nav-link-v4 {
      position: relative;
      padding: 6px 0;
    }
    .nav-link-v4::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 0;
      height: 2px;
      background: var(--c-bordeaux);
      transition: width 0.3s ease;
    }
    .nav-link-v4:hover {
      color: var(--c-bordeaux) !important;
    }
    .nav-link-v4:hover::after {
      width: 100%;
    }

    /* V4.2 — AEO mini badge next to logo */
    .aeo-mini-badge {
      padding: 6px 12px;
      background: var(--c-bordeaux);
      color: var(--c-cream);
      font-family: var(--f-display);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: background 0.2s ease, transform 0.15s ease;
      white-space: nowrap;
    }
    .aeo-mini-badge:hover {
      background: var(--c-bordeaux-deep);
      transform: translateY(-1px);
    }

    /* V4.6.4 — AEO badge pushed further down so it is fully visible below ticker */
    .aeo-rotating-badge {
      display: none;
      position: fixed;
      top: 180px;            /* clearly below sticky header (~96px) + ticker bar (~46px) + breathing room */
      left: 24px;
      z-index: 38;
      width: 80px;           /* slightly bigger for that "trust seal" feel */
      height: 80px;
      padding: 0;
      margin: 0;
      border: none;
      background: transparent;
      cursor: pointer;
      border-radius: 9999px;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      flex-shrink: 0;
      box-shadow: 0 6px 20px rgba(128, 0, 32, 0.18);
    }
    .aeo-rotating-badge:hover {
      transform: scale(1.05);
      box-shadow: 0 8px 24px rgba(128, 0, 32, 0.28);
    }
    @media (min-width: 1024px) {
      .aeo-rotating-badge { display: block; }
    }
    .aeo-rotating-badge:hover {
      transform: scale(1.06);
    }
    .aeo-rotating-badge:focus-visible {
      outline: 3px solid var(--c-copper);
      outline-offset: 3px;
      border-radius: 9999px;
    }
    .aeo-rotating-badge .aeo-ring-svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }
    /* Spin the textPath only — original AEO logo stays still */
    .aeo-rotating-badge .aeo-spin-text {
      transform-origin: 50% 50%;
      animation: aeoSpin 22s linear infinite;
    }
    .aeo-rotating-badge:hover .aeo-spin-text {
      animation-duration: 10s; /* speed up on hover */
    }
    .aeo-rotating-badge .aeo-logo-inner {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 56px;
      height: 56px;
      object-fit: contain;
      pointer-events: none;
    }
    @keyframes aeoSpin {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }
    @media (prefers-reduced-motion: reduce) {
      .aeo-rotating-badge .aeo-spin-text { animation: none; }
    }

    /* V4.6.4 — AEO popover, anchored to the floating badge (top:180, left:24, w:80) */
    .aeo-popover {
      position: fixed;
      top: 170px;
      left: 120px;          /* 24 (badge left) + 80 (badge w) + 16 (gap) */
      z-index: 60;
      width: 360px;
      max-width: calc(100vw - 160px);
      background: var(--c-cream);
      border: 1px solid var(--c-line);
      border-left: 3px solid var(--c-bordeaux);
      padding: 22px 24px 18px;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.18);
      opacity: 0;
      transform: translateX(-8px) scale(0.98);
      pointer-events: none;
      transition: opacity 0.25s ease, transform 0.25s ease;
    }
    .aeo-popover[data-open] {
      opacity: 1;
      transform: translateX(0) scale(1);
      pointer-events: auto;
    }
    .aeo-popover-close {
      position: absolute;
      top: 8px;
      right: 10px;
      width: 28px;
      height: 28px;
      background: transparent;
      border: none;
      font-size: 22px;
      color: var(--c-mute);
      cursor: pointer;
      line-height: 1;
      transition: color 0.2s ease;
    }
    .aeo-popover-close:hover {
      color: var(--c-bordeaux);
    }
    .aeo-popover-eyebrow {
      font-family: var(--f-mono);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--c-copper);
      margin: 0 0 8px;
    }
    .aeo-popover-title {
      font-family: var(--f-display);
      font-weight: 500;
      font-size: 22px;
      line-height: 1.2;
      color: var(--c-ink);
      margin: 0 0 12px;
    }
    .aeo-popover-lead {
      font-family: var(--f-sans);
      font-size: 14px;
      line-height: 1.55;
      color: var(--c-charcoal);
      margin: 0;
    }
    .aeo-popover-list {
      list-style: none;
      margin: 8px 0 0;
      padding: 0;
    }
    .aeo-popover-list li {
      font-family: var(--f-sans);
      font-size: 13.5px;
      line-height: 1.5;
      color: var(--c-charcoal);
      padding: 6px 0 6px 18px;
      position: relative;
    }
    .aeo-popover-list li::before {
      content: "→";
      position: absolute;
      left: 0;
      color: var(--c-bordeaux);
      font-weight: 600;
    }
    /* V4.6.1 — single bordeaux CTA + secondary link below */
    .aeo-popover-quote-cta {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 18px;
      font-size: 13px;
      padding: 10px 18px;
    }
    .aeo-popover-secondary-link {
      display: block;
      margin-top: 10px;
      font-family: var(--f-sans);
      font-size: 12.5px;
      font-weight: 500;
      color: var(--c-charcoal);
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .aeo-popover-secondary-link:hover {
      color: var(--c-bordeaux);
    }
    @media (max-width: 1023px) {
      .aeo-popover { display: none; }
    }

    /* V4.2 — Utility bar icons (search + lang) hover */
    .utility-icon-btn {
      border-radius: 0;
      transition: opacity 0.2s ease;
      opacity: 0.85;
    }
    .utility-icon-btn:hover {
      opacity: 1;
      color: var(--c-copper) !important;
    }
    .utility-icon-btn:hover svg {
      color: var(--c-copper) !important;
    }

    /* V4.2 — Language dropdown items */
    .lang-item:not(:disabled):hover {
      background: rgba(247,242,232,0.08);
      color: var(--c-copper) !important;
    }

    /* V4.1 — Header WhatsApp button GREEN (#25D366 official WhatsApp brand) */
    .header-whatsapp-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      background: #25D366;
      color: #FFFFFF;
      font-family: var(--f-display);
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.01em;
      border-radius: 0;
      transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
      box-shadow: 0 1px 3px rgba(37, 211, 102, 0.25);
    }
    .header-whatsapp-btn:hover {
      background: #1FAD52;
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(37, 211, 102, 0.35);
    }
    .header-whatsapp-btn:active {
      transform: translateY(0);
    }
    .header-whatsapp-btn svg {
      flex-shrink: 0;
    }

    /* Legacy nav-link (kept for backward compat, hidden if both present) */
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -22px;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--c-bordeaux);
      transition: width 0.3s ease;
    }
    .nav-link:hover::after {
      width: 100%;
    }
  </style>

  <script>
    // Mobile menu toggle
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
    }

    // V4.2 — Search overlay toggle
    const searchBtn = document.getElementById('search-btn');
    const searchOverlay = document.getElementById('search-overlay');
    const searchClose = document.getElementById('search-close');
    const searchInput = document.getElementById('search-input');
    if (searchBtn && searchOverlay) {
      searchBtn.addEventListener('click', () => {
        searchOverlay.classList.remove('hidden');
        setTimeout(() => (searchInput as HTMLInputElement)?.focus(), 50);
      });
      searchClose?.addEventListener('click', () => searchOverlay.classList.add('hidden'));
      searchOverlay.addEventListener('click', (e) => {
        if (e.target === searchOverlay) searchOverlay.classList.add('hidden');
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') searchOverlay.classList.add('hidden');
      });
    }

    // V4.2 — Language dropdown toggle
    const langBtn = document.getElementById('lang-btn');
    const langMenu = document.getElementById('lang-menu');
    if (langBtn && langMenu) {
      langBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isHidden = langMenu.classList.contains('hidden');
        langMenu.classList.toggle('hidden');
        langBtn.setAttribute('aria-expanded', String(isHidden));
      });
      document.addEventListener('click', (e) => {
        if (!langMenu.contains(e.target as Node) && e.target !== langBtn) {
          langMenu.classList.add('hidden');
          langBtn.setAttribute('aria-expanded', 'false');
        }
      });
    }

    // Intersection Observer for reveal animations
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

    /* V4.6 — AEO popover toggle (Deo 2026-05-20) */
    (function initAEOPopover() {
      const toggle = document.querySelector('[data-aeo-toggle]');
      const popover = document.querySelector('[data-aeo-popover]');
      const closeBtn = document.querySelector('[data-aeo-close]');
      if (!toggle || !popover) return;

      const open = () => {
        popover.removeAttribute('hidden');
        // next frame for transition
        requestAnimationFrame(() => popover.setAttribute('data-open', ''));
      };
      const close = () => {
        popover.removeAttribute('data-open');
        setTimeout(() => popover.setAttribute('hidden', ''), 250);
      };
      const toggleState = () => {
        if (popover.hasAttribute('data-open')) close();
        else open();
      };

      toggle.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleState();
      });
      closeBtn && closeBtn.addEventListener('click', close);

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (!popover.hasAttribute('data-open')) return;
        if (popover.contains(e.target) || toggle.contains(e.target)) return;
        close();
      });

      // Close on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && popover.hasAttribute('data-open')) close();
      });
    })();
  </script>
