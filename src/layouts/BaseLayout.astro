  <!-- ============== SCRIPTS ============== -->
  <style>
    /* Ticker animation */
    @keyframes tickerScroll {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }
    /* V4.6.2 — Ticker items are clickable links to /accreditations anchors */
    .ticker-link {
      color: inherit;
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .ticker-link:hover {
      color: var(--c-copper);
    }
    .ticker-track:hover {
