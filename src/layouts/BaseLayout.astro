---
import '@/styles/global.css';
import { site } from '@/lib/site';
import { getLangFromUrl, t } from '@/i18n/translations';
import Breadcrumb from '@/components/layout/Breadcrumb.astro';
import FloatingActions from '@/components/global/FloatingActions.astro';
import ServiceQuickNav from '@/components/global/ServiceQuickNav.astro';
import QuoteNudge from '@/components/global/QuoteNudge.astro';
import PromoBar from '@/components/global/PromoBar.astro';
import MeklucLogo from '@/components/global/MeklucLogo.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = site.seo.defaultDescription, ogImage } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const fullTitle = title === 'Home'
  ? `${site.name} — AEO Accredited Freight Forwarder South Africa`
  : site.seo.titleTemplate.replace('%s', title);
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />

  <title>{fullTitle}</title>

  <!-- Favicons -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="icon" sizes="192x192" href="/android-chrome-192x192.png" />
  <link rel="icon" sizes="512x512" href="/android-chrome-512x512.png" />

  <!-- Canonical -->
  <link rel="canonical" href={new URL(Astro.url.pathname, site.url).href} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={new URL(Astro.url.pathname, site.url).href} />
  <meta property="og:site_name" content={site.name} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Schema.org LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": site.name,
    "description": description,
    "url": site.url,
    "telephone": site.phone,
    "email": site.email,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": site.address.city,
      "addressRegion": site.address.province,
      "addressCountry": "ZA"
    },
    "foundingDate": "2007",
    "slogan": site.tagline,
    "areaServed": "South Africa"
  })} />
</head>
<body class="min-h-screen flex flex-col">

  <!-- ============== UTILITY BAR — V4.2: Phone prominent + Search + Language ============== -->
  <div style="background: var(--c-bordeaux); color: var(--c-cream);" class="relative z-50">
    <div class="section flex items-center justify-between" style="padding-top: 10px; padding-bottom: 10px;">
      <!-- Left: trust signals -->
      <div class="flex items-center gap-5">
        <span style="font-family: var(--f-mono); font-size: 13px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(247,242,232,0.85);">
          AEO Accredited
        </span>
        <span style="color: rgba(247,242,232,0.3);">|</span>
        <span class="hidden sm:inline" style="font-family: var(--f-mono); font-size: 13px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(247,242,232,0.85);">
          Level 1 B-BBEE
        </span>
        <span class="hidden sm:inline" style="color: rgba(247,242,232,0.3);">|</span>
        <span class="hidden md:inline" style="font-family: var(--f-mono); font-size: 13px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(247,242,232,0.85);">
          Since 2007
        </span>
      </div>
      <!-- Right: PHONE prominent + email + search + lang + STC -->
      <div class="flex items-center gap-4">
        <!-- Phone — MORE PROMINENT (V4.2) -->
        <a href={`tel:${site.phoneRaw}`} style="font-family: var(--f-display); font-size: 14px; font-weight: 700; color: var(--c-cream); transition: opacity 0.2s ease; letter-spacing: 0.02em;" class="hover:opacity-80 flex items-center gap-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {site.phone}
        </a>
        <span class="hidden sm:inline" style="color: rgba(247,242,232,0.3);">|</span>
        <!-- Email -->
        <a href={`mailto:${site.email}`} class="hidden sm:flex items-center gap-2" style="font-family: var(--f-display); font-size: 13px; font-weight: 500; color: rgba(247,242,232,0.9); transition: opacity 0.2s ease;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          {site.email}
        </a>
        <span class="hidden md:inline" style="color: rgba(247,242,232,0.3);">|</span>
        <!-- Search icon (V4.2) — opens search overlay -->
        <button id="search-btn" class="hidden md:inline-flex items-center gap-1.5 utility-icon-btn" aria-label="Search" style="background: transparent; border: none; cursor: pointer; padding: 4px 6px;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: rgba(247,242,232,0.85);"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </button>
        <!-- Language dropdown (V4.2) — EN active, FR/AF placeholders -->
        <div class="hidden md:flex relative" id="lang-switcher">
          <button id="lang-btn" class="utility-icon-btn flex items-center gap-1" aria-label="Change language" aria-expanded="false" style="background: transparent; border: none; cursor: pointer; padding: 4px 6px; font-family: var(--f-display); font-size: 13px; font-weight: 600; color: rgba(247,242,232,0.9); letter-spacing: 0.05em;">
            <span aria-hidden="true">🇿🇦</span><span>EN</span>
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <!-- Dropdown menu -->
          <div id="lang-menu" class="hidden absolute right-0 top-full mt-2" style="background: var(--c-ink); border: 1px solid rgba(247,242,232,0.15); min-width: 140px; z-index: 100; box-shadow: 0 8px 24px rgba(0,0,0,0.2);">
            <button class="lang-item lang-item-active" data-lang="en" style="display: flex; align-items: center; gap: 10px; width: 100%; padding: 10px 14px; font-family: var(--f-display); font-size: 13px; font-weight: 600; color: var(--c-cream); background: transparent; border: none; cursor: pointer; text-align: left;">
              <span>🇿🇦</span><span>English</span><span style="margin-left: auto; color: var(--c-copper); font-size: 11px;">●</span>
            </button>
            <button class="lang-item" data-lang="fr" style="display: flex; align-items: center; gap: 10px; width: 100%; padding: 10px 14px; font-family: var(--f-display); font-size: 13px; font-weight: 500; color: rgba(247,242,232,0.6); background: transparent; border: none; cursor: not-allowed; text-align: left;" disabled>
              <span>🇫🇷</span><span>Français</span><span style="margin-left: auto; font-size: 9px; color: rgba(247,242,232,0.4);">SOON</span>
            </button>
            <button class="lang-item" data-lang="af" style="display: flex; align-items: center; gap: 10px; width: 100%; padding: 10px 14px; font-family: var(--f-display); font-size: 13px; font-weight: 500; color: rgba(247,242,232,0.6); background: transparent; border: none; cursor: not-allowed; text-align: left;" disabled>
              <span>🇿🇦</span><span>Afrikaans</span><span style="margin-left: auto; font-size: 9px; color: rgba(247,242,232,0.4);">SOON</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Search overlay (V4.2) — hidden by default -->
  <div id="search-overlay" class="hidden fixed inset-0 z-[100] flex items-start justify-center pt-32" style="background: rgba(26,22,18,0.85); backdrop-filter: blur(8px);">
    <div class="w-full max-w-2xl px-6">
      <form action="/" method="get" role="search" style="position: relative;">
        <input type="search" name="q" id="search-input" placeholder="Search Mekluc Freight..." autocomplete="off" style="width: 100%; padding: 22px 60px 22px 24px; font-family: var(--f-display); font-size: 18px; background: var(--c-cream); border: 2px solid var(--c-bordeaux); color: var(--c-ink); outline: none;" />
        <button type="submit" aria-label="Submit search" style="position: absolute; right: 8px; top: 50%; transform: translateY(-50%); background: var(--c-bordeaux); color: var(--c-cream); border: none; cursor: pointer; padding: 12px 18px; font-family: var(--f-display); font-size: 14px; font-weight: 700;">
          Search
        </button>
      </form>
      <button id="search-close" aria-label="Close search" style="position: absolute; top: -48px; right: 24px; background: transparent; border: none; color: var(--c-cream); cursor: pointer; padding: 8px;">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
      <p style="text-align: center; color: rgba(247,242,232,0.6); font-family: var(--f-display); font-size: 13px; margin-top: 16px;">
        Press <kbd style="background: rgba(247,242,232,0.15); padding: 2px 8px; border-radius: 4px; font-family: var(--f-mono); font-size: 11px;">ESC</kbd> to close · Search is coming soon (V1.5)
      </p>
    </div>
  </div>

  <!-- ============== PROMO BAR (V4.6.2 — Deo 2026-05-20) ============== -->
  <!-- Renders ONLY when site.promo.active is true. Configure in src/lib/site.ts. -->
  <PromoBar />

  <!-- ============== HEADER — V4.1 (white bg, WhatsApp green, balanced) ============== -->
  <header class="sticky top-0 z-40 border-b border-mekluc-line-soft" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
    <nav class="section flex items-center justify-between" style="padding-top: 16px; padding-bottom: 16px;">

      <!-- LOGO + EST 2007 + AEO badge mini (V4.2) -->
      <div class="flex items-center gap-4">
        <a href="/" class="flex items-center gap-4" aria-label="Mekluc Freight — Home">
          <MeklucLogo variant="light" height={96} class="md:!h-[104px]" loading="eager" />
          <span class="hidden sm:block" style="width: 1px; height: 40px; background: var(--c-line);"></span>
          <span class="hidden sm:flex flex-col" style="font-family: var(--f-mono); font-size: 11px; font-weight: 500; color: var(--c-charcoal); letter-spacing: 0.14em; text-transform: uppercase; line-height: 1.4;">
            <span>Est. 2007</span>
            <span style="color: var(--c-bordeaux); font-weight: 700;">Johannesburg</span>
          </span>
        </a>
        <!-- AEO badge REMOVED from header flex (V4.6.3) — see floating element after </header> below -->

      </div>

      <!-- NAV LINKS — V4.1 spaced + 15px -->
      <div class="hidden lg:flex items-center" style="gap: 36px;">
        <a href="/about" style="font-family: var(--f-display); font-size: 15px; font-weight: 600; color: var(--c-ink); transition: color 0.2s ease;" class="nav-link-v4">
          {t(lang, 'nav.about')}
        </a>
        <a href="/services" style="font-family: var(--f-display); font-size: 15px; font-weight: 600; color: var(--c-ink); transition: color 0.2s ease;" class="nav-link-v4">
          {t(lang, 'nav.services')}
        </a>
        <a href="/solutions" style="font-family: var(--f-display); font-size: 15px; font-weight: 600; color: var(--c-ink); transition: color 0.2s ease;" class="nav-link-v4">
          {t(lang, 'nav.solutions')}
        </a>
        <a href="/tracking" style="font-family: var(--f-display); font-size: 15px; font-weight: 600; color: var(--c-ink); transition: color 0.2s ease;" class="nav-link-v4">
          Track
        </a>
        <a href="/insights" style="font-family: var(--f-display); font-size: 15px; font-weight: 600; color: var(--c-ink); transition: color 0.2s ease;" class="nav-link-v4">
          {t(lang, 'nav.insights')}
        </a>
        <a href="/contact" style="font-family: var(--f-display); font-size: 15px; font-weight: 600; color: var(--c-ink); transition: color 0.2s ease;" class="nav-link-v4">
          {t(lang, 'nav.contact')}
        </a>
      </div>

      <!-- CTA GROUP — V4.6.1 added left margin (md+) so Quote CTA doesn't overlap nav links -->
      <div class="flex items-center gap-3 md:ml-6 lg:ml-10">
        <!-- Quote button bordeaux -->
        <a href="/contact?quote=1" class="btn-primary">
          Request a quote <span class="btn-arrow">&rarr;</span>
        </a>
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="lg:hidden ml-2 p-2 text-mekluc-ink" aria-label="Open menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden border-t border-mekluc-line-soft bg-mekluc-paper">
      <div class="section py-6 flex flex-col gap-4">
        <a href="/about" class="font-sans text-[15px] font-medium text-mekluc-ink-soft hover:text-mekluc-bordeaux transition-colors py-2">About</a>
        <a href="/services" class="font-sans text-[15px] font-medium text-mekluc-ink-soft hover:text-mekluc-bordeaux transition-colors py-2">Services</a>
        <a href="/solutions" class="font-sans text-[15px] font-medium text-mekluc-ink-soft hover:text-mekluc-bordeaux transition-colors py-2">Solutions</a>
        <a href="/tracking" class="font-sans text-[15px] font-medium text-mekluc-ink-soft hover:text-mekluc-bordeaux transition-colors py-2">Track Shipment</a>
        <a href="/insights" class="font-sans text-[15px] font-medium text-mekluc-ink-soft hover:text-mekluc-bordeaux transition-colors py-2">Insights</a>
        <a href="/contact" class="font-sans text-[15px] font-medium text-mekluc-ink-soft hover:text-mekluc-bordeaux transition-colors py-2">Contact</a>
        <div class="flex gap-3 pt-4 border-t border-mekluc-line-soft">
          <a href={site.social.whatsappLink} target="_blank" rel="noopener" class="btn-whatsapp flex-1 justify-center">WhatsApp</a>
          <a href="/contact?quote=1" class="btn-primary flex-1 justify-center">Get a quote <span class="btn-arrow">&rarr;</span></a>
        </div>
      </div>
    </div>
  </header>

  <!-- ============== AEO ROTATING BADGE — V4.6.3 FLOATING FIXED LEFT ============== -->
  <!-- Pulled out of the header flex group so it can NEVER overlap nav text. -->
  <!-- Sits in the left edge of the page, below the header. Visible on all pages, ≥1024px. -->
  <button type="button" class="aeo-rotating-badge" aria-label="What AEO accreditation means" data-aeo-toggle>
    <svg class="aeo-ring-svg" viewBox="0 0 100 100" width="80" height="80" aria-hidden="true">
      <defs>
        <path id="aeo-text-circle" d="M 50,50 m -42,0 a 42,42 0 1,1 84,0 a 42,42 0 1,1 -84,0" />
      </defs>
      <circle cx="50" cy="50" r="49" fill="var(--c-cream)" />
      <circle cx="50" cy="50" r="48" fill="none" stroke="var(--c-bordeaux)" stroke-width="0.6" opacity="0.45" />
      <text class="aeo-spin-text" fill="var(--c-bordeaux)" font-family="var(--f-mono, monospace)" font-size="7" font-weight="700" letter-spacing="1.2">
        <textPath href="#aeo-text-circle" startOffset="0">
          · AUTHORISED ECONOMIC OPERATOR · SARS · MEKLUC ·
        </textPath>
      </text>
    </svg>
    <img src="/images/accreditation/mekluc-aeo-logo.svg" alt="AEO Mekluc — Authorised Economic Operator" class="aeo-logo-inner" />
  </button>

  <!-- AEO popover (anchored to floating badge) -->
  <div class="aeo-popover" data-aeo-popover hidden role="dialog" aria-label="AEO accreditation details">
    <button type="button" class="aeo-popover-close" aria-label="Close" data-aeo-close>&times;</button>
    <p class="aeo-popover-eyebrow">— AEO Accredited · SARS</p>
    <h3 class="aeo-popover-title">Authorised Economic Operator</h3>
    <p class="aeo-popover-lead">
      The highest tier of customs trust granted by SARS — held by less than 1% of South African forwarders.
    </p>
    <p class="aeo-popover-eyebrow" style="margin-top: 16px;">— Benefits for your cargo</p>
    <ul class="aeo-popover-list">
      <li>Pre-arrival customs clearance</li>
      <li>Reduced physical inspection rate</li>
      <li>Mutual recognition with EU, China, Japan, Switzerland</li>
    </ul>
    <a href="/contact?quote=1" class="btn-primary aeo-popover-quote-cta">
      Request your quote <span class="btn-arrow">&rarr;</span>
    </a>
    <a href="/accreditations#aeo" class="aeo-popover-secondary-link">See full accreditations &rarr;</a>
  </div>

  <!-- ============== TICKER — Trust Signals (V4.6.2 : items clickable -> /accreditations#anchor) ============== -->
  <div class="bg-mekluc-ink text-mekluc-cream py-[14px] overflow-hidden relative z-30">
    <div class="ticker-track flex gap-[60px] whitespace-nowrap font-mono text-eyebrow uppercase" style="animation: tickerScroll 50s linear infinite;">
      {[...Array(2)].map(() => (
        <>
          <a href="/accreditations#aeo" class="ticker-link inline-flex items-center gap-[14px] flex-shrink-0" aria-label="What AEO accreditation means">AEO South Africa <span class="w-[5px] h-[5px] bg-mekluc-copper rounded-full"></span></a>
          <a href="/accreditations#sars" class="ticker-link inline-flex items-center gap-[14px] flex-shrink-0" aria-label="What our SARS Customs Clearing Agent licence covers">SARS Customs Clearing Agent <span class="w-[5px] h-[5px] bg-mekluc-copper rounded-full"></span></a>
          <a href="/accreditations#bbbeel1" class="ticker-link inline-flex items-center gap-[14px] flex-shrink-0" aria-label="What Level 1 B-BBEE means for your procurement">Level 1 B-BBEE <span class="w-[5px] h-[5px] bg-mekluc-copper rounded-full"></span></a>
          <a href="/accreditations#bwo" class="ticker-link inline-flex items-center gap-[14px] flex-shrink-0" aria-label="100% Black Woman Owned">100% Black Woman Owned <span class="w-[5px] h-[5px] bg-mekluc-copper rounded-full"></span></a>
        </>
      ))}
    </div>
  </div>

  <!-- ============== BREADCRUMB (DHL-inspired, hidden on home) ============== -->
  <Breadcrumb />

  <!-- ============== MAIN CONTENT ============== -->
  <main class="flex-1 relative z-10">
    <slot />
  </main>

  <!-- ============== FOOTER ============== -->
  <footer class="bg-mekluc-ink text-mekluc-line">
    <div class="section pt-20 pb-10">
      <!-- Top grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-14 lg:gap-[60px] pb-14 border-b" style="border-color: rgba(216, 207, 194, 0.15);">
        <!-- Brand column — V4.6.3 use MeklucLogo wrapper (variant dark for ink bg) -->
        <div>
          <MeklucLogo variant="dark" height={60} class="mb-[18px]" loading="lazy" />
          <p class="font-display italic text-[19px] leading-[1.4] text-mekluc-line max-w-[32ch]">
            {site.tagline}
          </p>
          <p class="font-sans text-body-sm text-mekluc-charcoal mt-6">
            {site.address.full}
          </p>
        </div>

        <!-- Services -->
        <div>
          <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-mekluc-copper mb-[18px]">
            Services
          </p>
          <ul class="flex flex-col gap-[10px]">
            <li><a href="/services/air-freight" class="font-sans text-[14px] text-mekluc-line hover:text-mekluc-cream transition-colors">Air Freight</a></li>
            <li><a href="/services/sea-freight" class="font-sans text-[14px] text-mekluc-line hover:text-mekluc-cream transition-colors">Sea Freight</a></li>
            <li><a href="/services/road-freight" class="font-sans text-[14px] text-mekluc-line hover:text-mekluc-cream transition-colors">Road Freight</a></li>
            <li><a href="/services/customs-clearing" class="font-sans text-[14px] text-mekluc-line hover:text-mekluc-cream transition-colors">Customs Clearing</a></li>
            <li><a href="/services/warehousing" class="font-sans text-[14px] text-mekluc-line hover:text-mekluc-cream transition-colors">Warehousing</a></li>
            <li><a href="/services/packaging-crating" class="font-sans text-[14px] text-mekluc-line hover:text-mekluc-cream transition-colors">Packaging & Crating</a></li>
            <li><a href="/services/specialised-cargo" class="font-sans text-[14px] text-mekluc-line hover:text-mekluc-cream transition-colors">Specialised Cargo</a></li>
            <li><a href="/services/cargo-insurance" class="font-sans text-[14px] text-mekluc-line hover:text-mekluc-cream transition-colors">Cargo Insurance</a></li>
          </ul>
        </div>

        <!-- Company -->
        <div>
          <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-mekluc-copper mb-[18px]">
            Company
          </p>
          <ul class="flex flex-col gap-[10px]">
            <li><a href="/about" class="font-sans text-[14px] text-mekluc-line hover:text-mekluc-cream transition-colors">About Mekluc</a></li>
            <li><a href="/accreditations" class="font-sans text-[14px] text-mekluc-line hover:text-mekluc-cream transition-colors">Accreditations</a></li>
            <li><a href="/insights" class="font-sans text-[14px] text-mekluc-line hover:text-mekluc-cream transition-colors">Insights</a></li>
            <li><a href="/careers" class="font-sans text-[14px] text-mekluc-line hover:text-mekluc-cream transition-colors">Careers</a></li>
            <li><a href="/sustainability" class="font-sans text-[14px] text-mekluc-line hover:text-mekluc-cream transition-colors">Sustainability</a></li>
            <li><a href="/news" class="font-sans text-[14px] text-mekluc-line hover:text-mekluc-cream transition-colors">News & Press</a></li>
          </ul>
        </div>

        <!-- Contact -->
        <div>
