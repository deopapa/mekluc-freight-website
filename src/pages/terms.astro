---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/sections/PageHeader.astro';
import { site } from '@/lib/site';
---

<BaseLayout
  title="Terms of Service | Mekluc Freight South Africa"
  description="Mekluc Freight terms of service for freight forwarding, customs clearing, and related services."
>
  <PageHeader
    label="Legal"
    title="Terms of Service"
    subtitle="Terms governing our freight forwarding, customs clearing and related logistics services."
    bg="paper"
  />

  <section style="padding-top: clamp(5rem, 12vw, 10rem); padding-bottom: clamp(5rem, 12vw, 10rem);">
    <div class="section">
      <div class="max-w-3xl">
        <p style="font-family: var(--f-mono); font-size: 13px; letter-spacing: 0.12em; color: var(--c-mute); margin-bottom: 3rem;">LAST UPDATED: MAY 2026</p>

        <div class="legal-content">

          <section class="legal-section">
            <h2>1. About these terms</h2>
            <p>
              These terms of service ("Terms") govern your use of the {site.name} website and our provision of freight forwarding, customs clearing and related logistics services. By using our website or engaging our services, you agree to be bound by these Terms. If you do not agree, please do not use our website or services.
            </p>
          </section>

          <section class="legal-section">
            <h2>2. Services</h2>
            <p>{site.name} provides the following services:</p>
            <ul>
              <li>Freight forwarding — air, sea, road and multimodal</li>
              <li>Customs clearing — SARS-licensed Customs Clearing Agent, AEO-accredited</li>
              <li>Warehousing and bonded storage</li>
              <li>Cargo insurance arrangement</li>
              <li>Packaging and crating</li>
              <li>Specialised cargo handling — human remains (HUM), dangerous goods (DGR), live animals (AVI)</li>
              <li>Related logistics services as agreed between the parties</li>
            </ul>
            <p>All services are governed by the applicable written quotation, service agreement, and these Terms.</p>
          </section>

          <section class="legal-section">
            <h2>3. Standard Trading Conditions</h2>
            <p>
              All services are provided subject to the South African Association of Freight Forwarders (SAAFF) Standard Trading Conditions ("STC"), which are incorporated by reference into these Terms. The SAAFF STC govern liability, insurance, and the obligations of the parties unless expressly varied in writing. A copy of the SAAFF STC is available on request by contacting <a href={`mailto:${site.email}`}>{site.email}</a>.
            </p>
          </section>

          <section class="legal-section">
            <h2>4. Quotations and contracts</h2>
            <ul>
              <li>Quotations are valid for 14 calendar days from the date of issue, unless otherwise stated.</li>
              <li>All quotations are subject to availability of carrier space, equipment and routing.</li>
              <li>A binding contract is formed upon acceptance of a booking by {site.name}.</li>
              <li>Rates may change due to carrier surcharges, fuel adjustments, currency fluctuations or regulatory changes. Any such changes will be communicated before being applied.</li>
            </ul>
          </section>

          <section class="legal-section">
            <h2>5. Liability</h2>
            <p>Liability is limited by the applicable international conventions and the SAAFF STC:</p>
            <ul>
              <li><strong>Sea freight:</strong> Hague-Visby Rules</li>
              <li><strong>Air freight:</strong> Warsaw Convention / Montreal Convention</li>
              <li><strong>Road freight:</strong> SAAFF Standard Trading Conditions</li>
            </ul>
            <p>We strongly recommend that clients arrange appropriate cargo insurance for all shipments. {site.name} can assist with insurance arrangement on request.</p>
          </section>

          <section class="legal-section">
            <h2>6. Client obligations</h2>
            <p>As our client, you agree to:</p>
            <ul>
              <li>Provide accurate and complete information about your cargo, including weight, dimensions, value and contents</li>
              <li>Supply all required documentation in a timely manner (commercial invoices, packing lists, permits, licences)</li>
              <li>Accurately declare dangerous goods — misclassification carries criminal liability under South African and international law</li>
              <li>Pay invoices in accordance with agreed payment terms</li>
              <li>Comply with all applicable import, export and trade compliance laws</li>
            </ul>
          </section>

          <section class="legal-section">
            <h2>7. Payment terms</h2>
            <ul>
              <li>Standard payment terms are 14 to 30 days net from date of invoice. Specific terms may be agreed in writing for regular clients.</li>
              <li>Late payment will attract interest at the South African prime lending rate plus 2% per annum.</li>
              <li>{site.name} retains a lien over cargo and documents until all outstanding invoices are settled in full.</li>
            </ul>
          </section>

          <section class="legal-section">
            <h2>8. Cancellation and amendments</h2>
            <ul>
              <li><strong>Before pick-up:</strong> cancellation at no charge if notified within 4 business hours of booking confirmation.</li>
              <li><strong>After pick-up:</strong> actual costs incurred (carrier charges, storage, handling) will be invoiced.</li>
              <li><strong>Major amendments:</strong> changes to routing, cargo specifications or dates after booking may attract handling charges.</li>
              <li><strong>Force majeure:</strong> neither party is liable for delays or failures caused by events beyond reasonable control, including but not limited to port closures, strikes, natural disasters, government actions, pandemics, and sanctions.</li>
            </ul>
          </section>

          <section class="legal-section">
            <h2>9. Anti-fraud</h2>
            <div class="legal-callout">
              <p>
                <strong>{site.name} will NEVER communicate a change in our banking details by email.</strong> If you receive such a communication, contact us immediately on <a href={`tel:${site.phoneRaw}`}>{site.phone}</a> to verify. Always confirm that correspondence is from @mekluc.co.za.
              </p>
            </div>
          </section>

          <section class="legal-section">
            <h2>10. Confidentiality and data protection</h2>
            <p>
              All personal information is handled in accordance with our <a href="/privacy">Privacy Policy</a> and the Protection of Personal Information Act (POPIA).
            </p>
            <p>
              Commercial information shared between the parties in the course of our engagement is treated as confidential and will not be disclosed to third parties without written consent, except where required by law or regulatory obligation.
            </p>
          </section>

          <section class="legal-section">
            <h2>11. Intellectual property</h2>
            <p>
              The {site.name} name, logo, website content, and all associated materials are the intellectual property of {site.name}. No part of this website or our materials may be reproduced, distributed or used without prior written permission.
            </p>
          </section>

          <section class="legal-section">
            <h2>12. Dispute resolution</h2>
            <p>In the event of a dispute arising from or in connection with these Terms or our services, the parties agree to the following resolution process:</p>
            <ol>
              <li><strong>Good faith discussion</strong> — the parties will first attempt to resolve the dispute through direct negotiation within 14 business days.</li>
              <li><strong>SAAFF mediation</strong> — if direct negotiation fails, the dispute will be referred to mediation under the auspices of SAAFF.</li>
              <li><strong>South African courts</strong> — if mediation fails, the dispute will be subject to the jurisdiction of the South African courts.</li>
            </ol>
          </section>

          <section class="legal-section">
            <h2>13. Governing law</h2>
            <p>
              These Terms are governed by and construed in accordance with the laws of the Republic of South Africa.
            </p>
          </section>

          <section class="legal-section">
            <h2>14. Changes to these terms</h2>
            <p>
              These Terms were last updated in May 2026. We may update these Terms from time to time. Significant changes will be communicated to active clients by email. The current version will always be available on this page.
            </p>
          </section>

          <section class="legal-section">
            <h2>15. Contact</h2>
            <p>For questions about these terms of service:</p>
            <p>
              Email: <a href={`mailto:${site.email}`}>{site.email}</a><br />
              Phone: <a href={`tel:${site.phoneRaw}`}>{site.phone}</a><br />
              Address: {site.address.full}
            </p>
          </section>

        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .legal-section {
    padding: clamp(1.5rem, 3vw, 2.5rem) 0;
    border-top: 1px solid var(--c-line-soft);
  }

  .legal-section:first-child {
    border-top: none;
    padding-top: 0;
  }

  .legal-section h2 {
    font-family: var(--f-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--c-ink);
    margin-bottom: 0.75rem;
  }

  .legal-section p {
    font-family: var(--f-sans);
    font-size: 1.1875rem;
    line-height: 1.65;
    color: var(--c-charcoal);
    margin-bottom: 0.75rem;
  }

  .legal-section p:last-child {
    margin-bottom: 0;
  }

  .legal-section ul,
  .legal-section ol {
    font-family: var(--f-sans);
    font-size: 1.1875rem;
    line-height: 1.65;
    color: var(--c-charcoal);
    padding-left: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .legal-section li {
    margin-bottom: 0.375rem;
  }

  .legal-section a {
    color: var(--c-bordeaux);
    font-weight: 600;
  }

  .legal-section strong {
    color: var(--c-ink);
  }

  .legal-callout {
    padding: 20px 24px;
    background: var(--c-cream);
    border-left: 3px solid var(--c-bordeaux);
  }

  .legal-callout p {
    margin-bottom: 0;
  }
</style>
