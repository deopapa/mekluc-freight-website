---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/sections/PageHeader.astro';
import { site } from '@/lib/site';
---

<BaseLayout
  title="News & Awards | Mekluc Freight South Africa"
  description="Mekluc Freight news, press mentions, awards and industry recognition."
>
  <PageHeader
    label="News & Press"
    title="News, press mentions and milestones."
    subtitle="Mekluc Freight in the press, recent industry developments, and milestones from 19 years of operations."
    bg="paper"
  />

  <!-- AEO competitive-edge callout (V4.6.4 — Deo: AEO must be visible across the site) -->
  <section style="padding: clamp(2rem, 4vw, 3rem) 0; background: var(--c-cream);">
    <div class="section">
      <div class="max-w-4xl mx-auto reveal" style="display: flex; align-items: center; gap: 24px; padding: clamp(1.25rem, 2vw, 1.75rem) clamp(1.5rem, 3vw, 2rem); background: var(--c-paper); border-left: 4px solid var(--c-bordeaux); border-radius: 4px;">
        <div style="flex-shrink: 0; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center;">
          <img src="/images/accreditation/mekluc-aeo-logo.svg" alt="AEO accredited" style="width: 56px; height: 56px; object-fit: contain;" loading="lazy" />
        </div>
        <div style="flex: 1; min-width: 0;">
          <p class="eyebrow" style="font-family: var(--f-mono); font-size: 11px; font-weight: 700; letter-spacing: 0.18em; color: var(--c-bordeaux); text-transform: uppercase; margin: 0 0 4px;">— Our competitive edge for importers</p>
          <p style="font-family: var(--f-sans); font-size: 15px; line-height: 1.45; color: var(--c-ink); margin: 0;">
            <strong>AEO-accredited by SARS</strong> — top 1% of South African freight forwarders. Pre-arrival clearance, reduced inspections, mutual recognition with EU, China, Japan, Switzerland.
          </p>
        </div>
        <div style="flex-shrink: 0; display: flex; flex-direction: column; gap: 6px;">
          <a href="/insights/aeo-customs-clearance-time/" style="font-family: var(--f-sans); font-size: 13px; font-weight: 600; color: var(--c-bordeaux); text-decoration: none; white-space: nowrap;">Read the deep-dive &rarr;</a>
          <a href="/accreditations#aeo" style="font-family: var(--f-sans); font-size: 12.5px; color: var(--c-charcoal); text-decoration: none; white-space: nowrap;">Accreditation details &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent news -->
  <section style="padding-top: clamp(5rem, 12vw, 10rem); padding-bottom: clamp(5rem, 12vw, 10rem);">
    <div class="section">
      <div class="section-header reveal">
        <div>
          <p class="eyebrow mb-4">News</p>
          <h2 class="section-title">Recent news</h2>
        </div>
      </div>

      <div class="max-w-3xl" style="display: flex; flex-direction: column; gap: 0;">
        {[
          {
            date: '20 May 2026',
            tag: 'COMPANY',
            title: 'Mekluc Freight launches refreshed digital presence at meklucfreight.co.za',
            body: 'Mekluc Freight has launched a refreshed corporate website at meklucfreight.co.za alongside its updated brand identity. The new site brings together our service offer (Air, Sea, Road, Customs, Warehousing, Specialised Cargo) and our three priority solutions for South African importers and exporters: SA Export Diversification, Mining & Project Cargo to Africa, and Pharma & Perishables GDP-ready forwarding. Trilingual rollout (EN / FR / AF) follows over 2026.',
          },
          {
            date: 'May 2026',
            tag: 'BRAND',
            title: 'New visual identity — Brand Book v2.3 published internally',
            body: 'Following a multi-month strategic review, Mekluc Freight has consolidated its visual identity in Brand Book v2.3. The system codifies the bordeaux + carmin palette, the Plus Jakarta Sans + IBM Plex Mono pairing, and the freight-specific iconography used across the website, signatures, quotes and proposals. The book is the source of truth for all internal and external collateral going forward.',
          },
          {
            date: '2026',
            tag: 'MILESTONE',
            title: '19 years of South African freight forwarding (2007–2026)',
            body: 'Mekluc Freight enters its 19th year of operations in 2026. Founded by Anne-Marie Mandtoumbi in Johannesburg in 2007, the company has remained 100% Black Woman Owned, maintained Level 1 B-BBEE certification, and earned Authorised Economic Operator (AEO) status from SARS — placing it in the top tier of South African customs-trusted forwarders. The road to 20 years continues with our 2027 expansion plan for the Pharma, Mining and Export Diversification verticals.',
          },
        ].map((item, i) => (
          <article class="reveal" style={`padding: clamp(2rem, 4vw, 2.5rem) 0; ${i > 0 ? 'border-top: 1px solid var(--c-line-soft);' : ''}`}>
            <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 1rem;">
              <span style="font-family: var(--f-mono); font-size: 13px; letter-spacing: 0.18em; color: var(--c-bordeaux);">{item.tag}</span>
              <span style="font-family: var(--f-mono); font-size: 13px; color: var(--c-mute);">&middot;</span>
              <time style="font-family: var(--f-mono); font-size: 13px; letter-spacing: 0.06em; color: var(--c-mute);">{item.date}</time>
            </div>
            <h3 style="font-family: var(--f-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 400; line-height: 1.2; color: var(--c-ink); margin-bottom: 1rem;">{item.title}</h3>
            <p style="font-family: var(--f-sans); font-size: 1.1875rem; line-height: 1.65; color: var(--c-charcoal);">{item.body}</p>
          </article>
        ))}
      </div>

      <p style="font-family: var(--f-sans); font-size: 0.8125rem; color: var(--c-mute); margin-top: 2.5rem; max-width: 60ch;">
        Press mentions in Freight News, Engineering News, African Cargo and SAAFF Newsletter will be linked here as they appear.
      </p>
    </div>
  </section>

  <!-- Awards & recognition — cream band -->
  <section style="background: var(--c-cream); padding: clamp(5rem, 12vw, 8rem) 0;">
    <div class="section">
      <div class="section-header reveal">
        <div>
          <p class="eyebrow mb-4">Recognition</p>
          <h2 class="section-title">Awards & recognition</h2>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-px reveal" style="background: var(--c-line-soft);">
        <div style="background: var(--c-paper); padding: clamp(2rem, 4vw, 3rem);">
          <p style="font-family: var(--f-mono); font-size: 13px; letter-spacing: 0.18em; color: var(--c-copper); margin-bottom: 1.25rem;">CURRENT RECOGNITION</p>
          <div style="display: flex; flex-direction: column; gap: 16px;">
            {[
              { badge: 'AEO', label: 'AEO accreditation by SARS' },
              { badge: 'B-BBEE L1', label: 'Level 1 B-BBEE certification' },
              { badge: 'BWO', label: '100% Black Woman Owned' },
            ].map((item) => (
              <div style="display: flex; align-items: center; gap: 14px;">
                <span style="font-family: var(--f-mono); font-size: 13px; letter-spacing: 0.12em; color: var(--c-copper); background: rgba(176,122,79,0.08); padding: 6px 12px; flex-shrink: 0;">{item.badge}</span>
                <span style="font-family: var(--f-sans); font-size: 1.1875rem; color: var(--c-charcoal);">{item.label}</span>
              </div>
            ))}
          </div>
        </div>
        <div style="background: var(--c-paper); padding: clamp(2rem, 4vw, 3rem);">
          <p style="font-family: var(--f-mono); font-size: 13px; letter-spacing: 0.18em; color: var(--c-copper); margin-bottom: 1.25rem;">AWARDS PURSUING</p>
          <div style="display: flex; flex-direction: column; gap: 10px;">
            {[
              'Logistics Achiever Awards',
              'Women in Logistics Africa Awards',
              'African Cargo & Bulk Handling Awards',
            ].map((award) => (
              <div style="display: flex; align-items: flex-start; gap: 12px;">
                <span style="font-family: var(--f-mono); font-size: 14px; color: var(--c-bordeaux); margin-top: 3px; flex-shrink: 0;">&check;</span>
                <span style="font-family: var(--f-sans); font-size: 1.1875rem; line-height: 1.5; color: var(--c-charcoal);">{award}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Press contact -->
  <section style="padding-top: clamp(5rem, 12vw, 10rem); padding-bottom: clamp(5rem, 12vw, 10rem);">
    <div class="section">
      <div class="max-w-3xl reveal">
        <p class="eyebrow mb-4">Media</p>
        <h2 style="font-family: var(--f-display); font-weight: 400; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.1; color: var(--c-ink); margin-bottom: 1.5rem;">
          Press contact
        </h2>
        <p style="font-family: var(--f-sans); font-size: 1.1875rem; line-height: 1.65; color: var(--c-charcoal); margin-bottom: 2rem;">
          For media enquiries, interviews with Anne-Marie Mandtoumbi or comment on freight industry developments:
        </p>
        <div style="display: flex; flex-direction: column; gap: 1px; background: var(--c-line-soft);">
          <div style="background: var(--c-cream); padding: 16px 20px; display: flex; align-items: center; gap: 16px;">
            <span style="font-family: var(--f-mono); font-size: 13px; letter-spacing: 0.12em; color: var(--c-mute); width: 48px;">EMAIL</span>
            <a href={`mailto:${site.email}`} style="font-family: var(--f-sans); font-size: 1.1875rem; color: var(--c-bordeaux); font-weight: 600;">{site.email}</a>
          </div>
          <div style="background: var(--c-cream); padding: 16px 20px; display: flex; align-items: center; gap: 16px;">
            <span style="font-family: var(--f-mono); font-size: 13px; letter-spacing: 0.12em; color: var(--c-mute); width: 48px;">PHONE</span>
            <a href={`tel:${site.phoneRaw}`} style="font-family: var(--f-sans); font-size: 1.1875rem; color: var(--c-bordeaux); font-weight: 600;">{site.phone}</a>
          </div>
        </div>
        <p style="font-family: var(--f-sans); font-size: 0.8125rem; color: var(--c-mute); margin-top: 1.5rem;">
          We respond to media enquiries within 24 business hours.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="cta-band-bordeaux" style="padding: clamp(5rem, 12vw, 8rem) 0;">
    <div class="absolute right-[-60px] bottom-[-60px] select-none pointer-events-none" aria-hidden="true">
      <span style="font-family: var(--f-display); font-size: 400px; line-height: 1; font-weight: 400; font-style: italic; color: rgba(247,242,232,0.04);">M</span>
    </div>
    <div class="section relative z-10" style="text-align: center;">
      <h2 style="font-family: var(--f-display); font-weight: 400; font-size: clamp(2.25rem, 5vw, 3.75rem); line-height: 1.05; color: var(--c-cream); margin-bottom: 1rem;">
        Follow Mekluc Freight on <em style="color: var(--c-copper); font-style: italic;">LinkedIn.</em>
      </h2>
      <p style="font-family: var(--f-sans); font-size: clamp(0.9375rem, 1.4vw, 1.0625rem); line-height: 1.65; color: rgba(247,242,232,0.7); max-width: 48ch; margin: 0 auto 2.5rem;">
        Industry insights, company milestones and freight news from South Africa.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer" class="btn-white">Follow on LinkedIn <span class="btn-arrow">&rarr;</span></a>
        <a href="/insights" class="btn-outline-light">Read Mekluc Insights</a>
      </div>
    </div>
  </section>
</BaseLayout>
