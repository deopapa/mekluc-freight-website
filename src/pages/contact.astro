---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/sections/PageHeader.astro';
import { site } from '@/lib/site';
---

<BaseLayout
  title="Contact Mekluc Freight | Get a Quote | Sandton Johannesburg"
  description={`Get a freight quote, ask for advice or talk to our team. Based in Morningside, Sandton, Johannesburg. Phone ${site.phone}. Quote in less than 2h.`}
>
  <PageHeader
    bgImage="/mekluc-freight-website/images/hero/hero-contact.webp"
    label="Contact"
    title="Get a freight quote in less than 2h."
    subtitle="Tell us what you're moving. We come back with a transparent quote within 2 business hours — or pick up the phone and let's talk."
    cta={{ text: 'WhatsApp us now', href: site.social.whatsappLink }}
  />

  <!-- QUOTE FORM + CONTACT DETAILS -->
  <section style="padding-top: clamp(5rem, 12vw, 10rem); padding-bottom: clamp(5rem, 12vw, 10rem);">
    <div class="section">
      <!-- Section header -->
      <div class="section-header reveal">
        <div>
          <p class="eyebrow mb-4">Request a quote</p>
          <h2 class="section-title">Tell us what you're <em>moving</em></h2>
        </div>
        <p class="section-lead">Fill in as much as you can. We'll come back with a clear, transparent quote — no hidden fees, no surprises.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16 reveal">

        <!-- QUOTE FORM — 3/5 -->
        <div class="lg:col-span-3">
          <form class="quote-form" id="quoteForm">
            <!-- Name & Company -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div class="form-group">
                <label for="name">Full Name <span style="color: var(--c-bordeaux);">*</span></label>
                <input type="text" id="name" name="name" required />
              </div>
              <div class="form-group">
                <label for="company">Company</label>
                <input type="text" id="company" name="company" />
              </div>
            </div>

            <!-- Email & Phone -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div class="form-group">
                <label for="email">Email <span style="color: var(--c-bordeaux);">*</span></label>
                <input type="email" id="email" name="email" required />
              </div>
              <div class="form-group">
                <label for="phone">Phone</label>
                <input type="tel" id="phone" name="phone" />
              </div>
            </div>

            <!-- Service -->
            <div class="form-group">
              <label for="service">Service Required</label>
              <select id="service" name="service">
                <option value="">Select a service...</option>
                <option value="air">Air freight</option>
                <option value="sea">Sea freight</option>
                <option value="road">Road freight</option>
                <option value="customs">Customs clearing only</option>
                <option value="mining">Mining or project cargo</option>
                <option value="pharma">Pharma or perishables (GDP)</option>
                <option value="hum">Human remains (HUM)</option>
                <option value="dgr">Dangerous goods (DGR)</option>
                <option value="avi">Live animals (AVI)</option>
                <option value="warehousing">Warehousing</option>
                <option value="other">Other</option>
              </select>
            </div>

            <!-- Origin & Destination -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div class="form-group">
                <label for="origin">Origin (country / city)</label>
                <input type="text" id="origin" name="origin" placeholder="e.g. Johannesburg, South Africa" />
              </div>
              <div class="form-group">
                <label for="destination">Destination (country / city)</label>
                <input type="text" id="destination" name="destination" placeholder="e.g. Lubumbashi, DRC" />
              </div>
            </div>

            <!-- Preferred dates -->
            <div class="form-group">
              <label for="dates">Preferred dates <span style="color: var(--c-mute); font-weight: 400;">(optional)</span></label>
              <input type="text" id="dates" name="dates" placeholder="e.g. First week of June 2026" />
            </div>

            <!-- Urgency -->
            <label class="urgency-check">
              <input type="checkbox" id="urgent" name="urgent" />
              <span>This is an urgent / time-critical shipment</span>
            </label>

            <!-- Message -->
            <div class="form-group">
              <label for="message">Tell us about your cargo <span style="color: var(--c-bordeaux);">*</span></label>
              <textarea id="message" name="message" rows="5" required
                placeholder="Describe your cargo, weight, dimensions and any special requirements (temperature control, permits, hazardous classification)..."></textarea>
            </div>

            <button type="submit" class="btn-primary" style="margin-top: 0.5rem;">
              Send Quote Request <span class="btn-arrow">&rarr;</span>
            </button>
          </form>
        </div>

        <!-- CONTACT SIDEBAR — 2/5 -->
        <div class="lg:col-span-2" style="display: flex; flex-direction: column; gap: 24px;">

          <!-- Direct contact -->
          <div class="contact-card">
            <h3 class="contact-card-title">Direct contact</h3>
            <div class="contact-item">
              <span class="contact-label">Phone</span>
              <a href={`tel:${site.phoneRaw}`} class="contact-value">{site.phone}</a>
              <p class="contact-note">Mon&ndash;Fri 08:00&ndash;17:00 SAST</p>
              <p class="contact-note" style="color: var(--c-bordeaux); font-weight: 600;">24/7 emergency line for HUM and DGR</p>
            </div>
            <div class="contact-item">
              <span class="contact-label">Email</span>
              <a href={`mailto:${site.email}`} class="contact-value">{site.email}</a>
              <p class="contact-note">We respond within 2 business hours</p>
            </div>
            <div class="contact-item">
              <span class="contact-label">WhatsApp</span>
              <a href={site.social.whatsappLink} target="_blank" rel="noopener noreferrer" class="contact-value" style="color: #25D366;">Chat on WhatsApp &rarr;</a>
            </div>
          </div>

          <!-- Response times -->
          <div class="contact-card">
            <h3 class="contact-card-title">Response times</h3>
            <div style="display: grid; gap: 0;">
              {[
                { channel: 'Phone', hours: 'Mon-Fri 08:00-17:00', time: 'Immediate' },
                { channel: 'Email', hours: '24/7', time: '< 2 business hours' },
                { channel: 'Quote form', hours: '24/7', time: '< 2 business hours' },
                { channel: 'HUM emergency', hours: '24/7', time: '< 1 hour', urgent: true },
                { channel: 'DGR urgent', hours: 'Mon-Sun 06:00-22:00', time: '< 4 hours', urgent: true },
              ].map((r) => (
                <div class="response-row">
                  <span style={`font-family: var(--f-sans); font-size: 1rem; font-weight: ${r.urgent ? '600' : '500'}; color: ${r.urgent ? 'var(--c-bordeaux)' : 'var(--c-ink)'};`}>{r.channel}</span>
                  <span style="font-family: var(--f-sans); font-size: 0.8125rem; color: var(--c-charcoal);">{r.hours}</span>
                  <span style="font-family: var(--f-mono); font-size: 0.75rem; letter-spacing: 0.05em; color: var(--c-copper);">{r.time}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Office -->
          <div class="contact-card">
            <h3 class="contact-card-title">Office</h3>
            <p style="font-family: var(--f-sans); font-size: 1.1875rem; line-height: 1.65; color: var(--c-charcoal);">{site.address.full}</p>
            <p style="font-family: var(--f-sans); font-size: 0.8125rem; color: var(--c-mute); margin-top: 0.5rem;">Visits welcome by appointment</p>
          </div>

          <!-- Accreditations -->
          <div class="contact-card">
            <h3 class="contact-card-title">Accreditations</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
              {site.accreditations.map((a) => (
                <span class="accred-badge">{a.short}</span>
              ))}
            </div>
            <p style="font-family: var(--f-sans); font-size: 0.75rem; color: var(--c-mute); margin-top: 0.75rem;">Details available to clients on request</p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAND — dark ink -->
  <section style="background: var(--c-ink); padding: clamp(4rem, 8vw, 6rem) 0;">
    <div class="section" style="text-align: center;">
      <p style="font-family: var(--f-mono); font-size: 14px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--c-copper); margin-bottom: 1rem;">Trusted by South African businesses</p>
      <p style="font-family: var(--f-sans); font-size: 1.1875rem; font-weight: 600; color: var(--c-cream); line-height: 1.8;">
        AEO South Africa &middot; SARS Customs Clearing Agent &middot; Level 1 B-BBEE &middot; SAAFF Member &middot; 100% Black Woman Owned
      </p>
      <p style="font-family: var(--f-sans); font-size: 0.8125rem; color: var(--c-mute); margin-top: 0.75rem;">
        Accreditation details available to clients on request &mdash; for fraud prevention.
      </p>
    </div>
  </section>

  <!-- CTA BAND — bordeaux -->
  <section class="cta-band-bordeaux" style="padding: clamp(4rem, 10vw, 7rem) 0;">
    <div class="absolute right-[-40px] bottom-[-40px] select-none pointer-events-none" aria-hidden="true">
      <span style="font-family: var(--f-serif); font-size: 300px; line-height: 1; font-weight: 400; font-style: italic; color: rgba(247,242,232,0.04);">M</span>
    </div>
    <div class="section relative z-10" style="text-align: center;">
      <h2 style="font-family: var(--f-serif); font-weight: 400; font-size: clamp(2rem, 4.5vw, 3.25rem); line-height: 1.1; color: var(--c-cream); margin-bottom: 1rem;">
        Prefer to <em style="color: var(--c-copper); font-style: italic;">talk?</em>
      </h2>
      <p style="font-family: var(--f-sans); font-size: clamp(0.9375rem, 1.4vw, 1.0625rem); line-height: 1.65; color: rgba(247,242,232,0.7); max-width: 48ch; margin: 0 auto 2rem;">
        Call us at <a href={`tel:${site.phoneRaw}`} style="color: var(--c-cream); text-decoration: underline; text-underline-offset: 3px;">{site.phone}</a> or walk into our Sandton office. We're real people.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`tel:${site.phoneRaw}`} class="btn-white">Call now <span class="btn-arrow">&rarr;</span></a>
        <a href={site.social.whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-outline-light">WhatsApp us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* V3 Contact form styles */
  .quote-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group label {
    font-family: var(--f-sans);
    font-size: 1rem;
    font-weight: 600;
    color: var(--c-ink);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    font-family: var(--f-sans);
    font-size: 1.1875rem;
    color: var(--c-ink);
    background: var(--c-ivory);
    border: 1px solid var(--c-line);
    padding: 14px 18px;
    transition: border-color 0.2s ease;
    width: 100%;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--c-bordeaux);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--c-mute);
  }

  .form-group select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L6 6L11 1' stroke='%236B645E' stroke-width='1.5'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: 44px;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 140px;
  }

  .urgency-check {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    cursor: pointer;
    padding: 12px 0;
  }

  .urgency-check input[type="checkbox"] {
    margin-top: 2px;
    width: 18px;
    height: 18px;
    accent-color: var(--c-bordeaux);
    flex-shrink: 0;
  }

  .urgency-check span {
    font-family: var(--f-sans);
    font-size: 1.1875rem;
    color: var(--c-ink);
  }

  /* Contact cards */
  .contact-card {
    padding: 28px;
    background: var(--c-cream);
    border: 1px solid var(--c-line-soft);
  }

  .contact-card-title {
    font-family: var(--f-serif);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--c-ink);
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--c-line);
  }

  .contact-item {
    padding: 12px 0;
    border-bottom: 1px solid var(--c-line-soft);
  }

  .contact-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .contact-label {
    font-family: var(--f-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-mute);
    display: block;
    margin-bottom: 4px;
  }

  .contact-value {
    font-family: var(--f-sans);
    font-size: 1.1875rem;
    font-weight: 600;
    color: var(--c-ink);
    transition: color 0.2s;
  }

  .contact-value:hover {
    color: var(--c-bordeaux);
  }

  .contact-note {
    font-family: var(--f-sans);
    font-size: 0.8125rem;
    color: var(--c-charcoal);
    margin-top: 4px;
  }

  .response-row {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 12px;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid var(--c-line-soft);
  }

  .response-row:last-child {
    border-bottom: none;
  }

  .accred-badge {
    font-family: var(--f-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-bordeaux);
    background: rgba(128, 0, 32, 0.06);
    padding: 6px 12px;
    border: 1px solid rgba(128, 0, 32, 0.12);
  }
</style>
