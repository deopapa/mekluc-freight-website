---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/sections/PageHeader.astro';
import { site } from '@/lib/site';

/**
 * /data-deletion
 *
 * Data Deletion Instructions page. Required by Meta to publish the
 * "Mekluc Freight Chatbot" app (WhatsApp Business Cloud API) — Meta App Review
 * mandates a public "Data Deletion Instructions URL".
 *
 * Also serves POPIA (Protection of Personal Information Act, SA) — right to
 * deletion. Linked from /privacy section 9.
 */
const WHATSAPP_DISPLAY = '+27 63 893 3653';
---

<BaseLayout
  title="Data Deletion Instructions | Mekluc Freight South Africa"
  description="How to request deletion of your personal data and WhatsApp conversation records held by Mekluc Freight. POPIA-compliant."
>
  <PageHeader
    label="Legal"
    title="Data Deletion Instructions"
    subtitle="How to request deletion of the personal data we hold about you, including your WhatsApp conversation records."
    bg="paper"
  />

  <section style="padding-top: clamp(5rem, 12vw, 10rem); padding-bottom: clamp(5rem, 12vw, 10rem);">
    <div class="section">
      <div class="max-w-3xl">
        <p style="font-family: var(--f-mono); font-size: 13px; letter-spacing: 0.12em; color: var(--c-mute); margin-bottom: 3rem;">LAST UPDATED: 29 MAY 2026</p>

        <div class="legal-content">

          <section class="legal-section">
            <h2>1. Your right to deletion</h2>
            <p>
              Under the Protection of Personal Information Act 4 of 2013 (POPIA), you have the right to request that {site.name} deletes the personal information we hold about you, subject to the legal retention obligations described below.
            </p>
            <p>
              This includes data from your conversations with us on WhatsApp ({WHATSAPP_DISPLAY}), our automated WhatsApp assistant, our website forms, and email.
            </p>
          </section>

          <section class="legal-section">
            <h2>2. What data we may hold from WhatsApp conversations</h2>
            <ul>
              <li>Your WhatsApp display name and phone number</li>
              <li>The content of messages you exchanged with us</li>
              <li>Documents and media you sent us (bills of lading, packing lists, cargo photos, invoices)</li>
              <li>Quote requests and shipment details you shared</li>
            </ul>
          </section>

          <section class="legal-section">
            <h2>3. How to request deletion</h2>
            <p>To request deletion of your personal data, contact our Information Officer using any of these channels:</p>
            <ul>
              <li><strong>Email:</strong> <a href={`mailto:${site.email}?subject=Data%20Deletion%20Request`}>{site.email}</a> with the subject line "Data Deletion Request"</li>
              <li><strong>WhatsApp:</strong> send the message <strong>"DELETE MY DATA"</strong> to {WHATSAPP_DISPLAY}</li>
              <li><strong>Phone:</strong> <a href={`tel:${site.phoneRaw}`}>{site.phone}</a></li>
              <li><strong>Post:</strong> {site.address.full}</li>
            </ul>
            <p>
              Please include the phone number or email address you used to contact us, so we can locate your records. We may ask you to verify your identity before processing the request, to protect your data from unauthorised deletion.
            </p>
          </section>

          <section class="legal-section">
            <h2>4. What happens next</h2>
            <ul>
              <li>We acknowledge your request within <strong>5 business days</strong>.</li>
              <li>We delete or anonymise the personal data we are not legally required to keep within <strong>30 calendar days</strong>.</li>
              <li>We confirm in writing once the deletion is complete.</li>
            </ul>
          </section>

          <section class="legal-section">
            <h2>5. Data we must retain by law</h2>
            <p>
              Some information cannot be deleted on request because we are legally obliged to keep it. This includes:
            </p>
            <ul>
              <li><strong>Customs clearance records</strong> — 5 years (required by SARS)</li>
              <li><strong>Tax and accounting records</strong> — as required by South African tax law</li>
              <li><strong>Records required for AEO accreditation audits</strong></li>
            </ul>
            <p>
              Where we must retain such records, we restrict access to them and delete them once the legal retention period expires.
            </p>
          </section>

          <section class="legal-section">
            <h2>6. Opting out without full deletion</h2>
            <p>
              If you simply want to stop receiving WhatsApp messages from us without deleting your records, send <strong>"STOP"</strong> to {WHATSAPP_DISPLAY} at any time. We will stop messaging you on WhatsApp.
            </p>
          </section>

          <section class="legal-section">
            <h2>7. Contact</h2>
            <p>For any question about data deletion or how we handle your personal information:</p>
            <p>
              Email: <a href={`mailto:${site.email}`}>{site.email}</a><br />
              Phone: <a href={`tel:${site.phoneRaw}`}>{site.phone}</a><br />
              Address: {site.address.full}
            </p>
            <p>
              See also our <a href="/privacy">Privacy Policy</a> for full details of how we handle personal information.
            </p>
          </section>

        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .legal-section {
    padding: clamp(1.5rem, 3vw, 2.5rem) 0;
    border-top: 1px solid var(--c-line-soft);
  }

  .legal-section:first-child {
    border-top: none;
    padding-top: 0;
  }

  .legal-section h2 {
    font-family: var(--f-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--c-ink);
    margin-bottom: 0.75rem;
  }

  .legal-section p {
    font-family: var(--f-sans);
    font-size: 1.1875rem;
    line-height: 1.65;
    color: var(--c-charcoal);
    margin-bottom: 0.75rem;
  }

  .legal-section p:last-child {
    margin-bottom: 0;
  }

  .legal-section ul,
  .legal-section ol {
    font-family: var(--f-sans);
    font-size: 1.1875rem;
    line-height: 1.65;
    color: var(--c-charcoal);
    padding-left: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .legal-section li {
    margin-bottom: 0.375rem;
  }

  .legal-section a {
    color: var(--c-bordeaux);
    font-weight: 600;
  }

  .legal-section strong {
    color: var(--c-ink);
  }
</style>
