## Mekluc Freight — Environment variables example
## Copy this file to .env (or .env.local) and fill in values
## DO NOT commit .env or .env.local — they are in .gitignore

# Site URL (auto-detected by Astro from astro.config but can be overridden)
PUBLIC_SITE_URL=https://meklucfreight.co.za

# Analytics (optional — when added)
# PUBLIC_PLAUSIBLE_DOMAIN=meklucfreight.co.za
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Form submission backend (when wired up)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
# CONTACT_FORM_TO_EMAIL=info@mekluc.co.za

# Cloudflare Pages env (set in Cloudflare dashboard, not here)
# NODE_VERSION=20
